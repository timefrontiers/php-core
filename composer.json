{
  "name": "timefrontiers/php-core",
  "description": "Core utilities, enums, and helpers for TimeFrontiers packages",
  "type": "library",
  "license": "MIT",
  "keywords": ["php", "core", "utilities", "enums", "helpers", "phone"],
  "authors": [
    {
      "name": "TimeFrontiers",
      "email": "dev@timefrontiers.com",
      "homepage": "https://timefrontiers.com"
    }
  ],
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "giggsey/libphonenumber-for-php": "^8.13"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "suggest": {
    "timefrontiers/php-validator": "For request parameter validation",
    "timefrontiers/php-session": "For CSRF token validation"
  },
  "autoload": {
    "psr-4": {
      "TimeFrontiers\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "TimeFrontiers\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true
  }
}
